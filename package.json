{
  "name": "bettersaver.github.io-tina",
  "version": "0.0.1",
  "description": "A starter for TinaCMS with Hugo",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i themes/bettersaver/assets/ananke/css/tailwind.css -o themes/bettersaver/assets/ananke/css/bettersaver/tailwind-built.css --minify",
    "watch:css": "tailwindcss -i themes/bettersaver/assets/ananke/css/tailwind.css -o themes/bettersaver/assets/ananke/css/bettersaver/tailwind-built.css --watch",
    "dev": "npm run build:css && NODE_OPTIONS=--dns-result-order=ipv4first concurrently --kill-others-on-fail -n css,site -c cyan,green \"npm:watch:css\" \"tinacms dev -c 'hugo server -D --bind 0.0.0.0'\"",
    "build": "npm run build:css && tinacms build && hugo",
    "build-local": "npm run build:css && tinacms build --local --skip-indexing --skip-cloud-checks && hugo",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tinalabs/vanilla-hugo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/tinalabs/vanilla-hugo/issues"
  },
  "homepage": "https://github.com/tinalabs/vanilla-hugo#readme",
  "dependencies": {
    "@tinacms/auth": "^1.1.2",
    "@tinacms/cli": "^2.1.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tinacms": "^2.10.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0"
  }
}
